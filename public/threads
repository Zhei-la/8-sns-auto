<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ThreadsAuto — Threads 자동화 툴</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#0e0e0f;--bg2:#161618;--bg3:#1e1e21;--bg4:#252528;
  --gold:#c9a96e;--gold2:#e8c98a;--gold-dim:rgba(201,169,110,0.12);--gold-border:rgba(201,169,110,0.25);
  --text:#f0ede8;--text2:#9e9b95;--text3:#5a5855;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);
  --radius:14px;--radius-sm:8px;--radius-pill:30px;
}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;line-height:1.7;}
a{text-decoration:none;color:inherit;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(14,14,15,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 32px;}
.nav-inner{max-width:1100px;margin:0 auto;height:64px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'Noto Serif KR',serif;font-size:18px;font-weight:700;color:var(--gold);}
.nav-cta{background:var(--gold);color:#0e0e0f;padding:9px 22px;border-radius:var(--radius-sm);font-size:13px;font-weight:700;}

/* HERO */
.hero{padding:140px 32px 100px;text-align:center;max-width:820px;margin:0 auto;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--gold-dim);color:var(--gold2);font-size:12px;padding:6px 16px;border-radius:var(--radius-pill);border:1px solid var(--gold-border);margin-bottom:32px;font-weight:500;}
.hero-badge span{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:pulse 2s infinite;display:inline-block;}
.hero h1{font-family:'Noto Serif KR',serif;font-size:clamp(34px,5vw,58px);font-weight:700;line-height:1.25;margin-bottom:24px;}
.hero h1 em{font-style:normal;color:var(--gold);}
.hero p{font-size:17px;color:var(--text2);margin-bottom:44px;max-width:560px;margin-left:auto;margin-right:auto;font-weight:300;line-height:1.9;}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.btn-main{background:var(--gold);color:#0e0e0f;padding:15px 36px;border-radius:var(--radius-sm);font-size:15px;font-weight:700;display:inline-flex;align-items:center;gap:8px;}
.btn-ghost{background:transparent;color:var(--text);padding:15px 36px;border-radius:var(--radius-sm);font-size:15px;border:1px solid var(--border2);}

.line{border:none;border-top:1px solid var(--border);}

/* STATS */
.stats{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:48px 32px;}
.stats-inner{max-width:1100px;margin:0 auto;display:flex;flex-direction:row;justify-content:center;align-items:center;gap:60px;flex-wrap:nowrap;text-align:center;}
.stat-num{font-family:'Noto Serif KR',serif;font-size:40px;font-weight:700;color:var(--gold);}
.stat-label{font-size:13px;color:var(--text3);margin-top:6px;}

/* SECTIONS */
.wrap{padding:60px 32px;max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:20px;}
.big-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:48px;text-align:center;}
.big-card.gold-border{border-color:var(--gold-border);}
.card-title{font-family:'Noto Serif KR',serif;font-size:clamp(22px,3vw,30px);font-weight:700;margin-bottom:16px;color:var(--gold);}
.card-sub{font-size:14px;color:var(--text2);margin-bottom:28px;font-weight:300;line-height:1.9;max-width:580px;margin-left:auto;margin-right:auto;}

/* FEATURE GRID */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-top:8px;text-align:left;}
.feat-item{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:24px;}
.feat-icon{font-size:24px;margin-bottom:12px;}
.feat-title{font-size:15px;font-weight:700;margin-bottom:8px;}
.feat-desc{font-size:13px;color:var(--text2);line-height:1.8;font-weight:300;}
.feat-tag{display:inline-block;margin-top:10px;font-size:11px;color:var(--gold);border:1px solid var(--gold-border);padding:2px 10px;border-radius:20px;background:var(--gold-dim);}

/* COMPARE */
.compare-table{margin-top:8px;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.compare-row{display:grid;grid-template-columns:1fr 1fr 1fr;text-align:center;}
.compare-row.header{background:var(--bg3);font-size:13px;font-weight:700;color:var(--text2);}
.compare-cell{padding:13px 10px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);font-size:13px;}
.compare-cell:last-child{border-right:none;}
.compare-row:last-child .compare-cell{border-bottom:none;}
.compare-cell.highlight{background:var(--gold-dim);color:var(--gold);}
.compare-cell.header.highlight{background:var(--gold-dim);color:var(--gold2);font-weight:700;}
.check{color:var(--gold);}
.cross{color:var(--text3);}
.partial{color:var(--text2);font-size:11px;}

/* PRICING */
.price-grid{display:flex;flex-direction:column;gap:10px;margin-top:8px;}
.price-item{display:flex;flex-direction:column;align-items:center;text-align:center;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);padding:28px;position:relative;}
.price-item.highlight{border-color:var(--gold-border);}
.price-pop{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--gold);color:#0e0e0f;font-size:10px;font-weight:700;padding:3px 14px;border-radius:20px;white-space:nowrap;}
.p-grade{font-size:12px;color:var(--text3);margin-bottom:6px;}
.p-name{font-family:'Noto Serif KR',serif;font-size:20px;font-weight:700;margin-bottom:14px;}
.p-amount{font-size:30px;font-weight:700;color:var(--gold);margin-bottom:4px;font-family:'Noto Serif KR',serif;}
.p-amount span{font-size:13px;color:var(--text3);font-weight:300;font-family:'Noto Sans KR',sans-serif;}
.p-period{font-size:12px;color:var(--text3);margin-bottom:18px;}
.p-list{list-style:none;margin-bottom:0;width:100%;max-width:320px;}
.p-list li{font-size:12px;padding:7px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:center;gap:8px;color:var(--text2);}
.p-list li:last-child{border:none;}
.p-list li::before{content:'';width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0;}

/* STEPS */
.steps-list{display:flex;flex-direction:column;gap:0;margin-top:8px;text-align:left;}
.step-item{display:flex;align-items:flex-start;gap:20px;padding:20px 24px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:10px;}
.step-num{width:40px;height:40px;background:var(--gold-dim);border:1px solid var(--gold-border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Noto Serif KR',serif;font-size:16px;font-weight:700;color:var(--gold);flex-shrink:0;}
.step-content h4{font-size:15px;font-weight:700;margin-bottom:6px;}
.step-content p{font-size:13px;color:var(--text2);line-height:1.8;font-weight:300;}

/* TAGS */
.tags{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:28px;justify-content:center;}
.tag{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius-pill);padding:8px 16px;font-size:13px;color:var(--text2);}

/* CTA */
.cta-wrap{background:var(--bg2);border-top:1px solid var(--border);}
.cta-inner{max-width:700px;margin:0 auto;padding:90px 32px;text-align:center;}
.cta-inner h2{font-family:'Noto Serif KR',serif;font-size:clamp(24px,3vw,36px);font-weight:700;margin-bottom:16px;line-height:1.4;}
.cta-inner p{font-size:15px;color:var(--text2);margin-bottom:36px;font-weight:300;line-height:1.9;}

footer{background:var(--bg);border-top:1px solid var(--border);padding:32px;text-align:center;}
footer p{font-size:12px;color:var(--text3);line-height:2;}
footer strong{color:var(--gold);font-weight:500;}

/* 애니메이션 */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
.reveal.visible{opacity:1;transform:none;}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
</style>
</head>
